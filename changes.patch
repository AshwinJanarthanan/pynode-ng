+<script>
+function gbToggleOverlay(id, btn) {
+    var backdrop = document.getElementById(id);
+    var isOpen = backdrop.classList.contains('gb-overlay-open');
+    document.querySelectorAll('.gb-overlay-backdrop').forEach(function(el) {
+        el.classList.remove('gb-overlay-open');
+    });
+    document.querySelectorAll('.gb-btn').forEach(function(el) {
+        el.classList.remove('gb-active');
+    });
+    if (!isOpen) {
+        if (id === 'docsOverlay') {
+            var src = document.getElementById('docus');
+            if (src) document.getElementById('docsOverlayBody').innerHTML = src.innerHTML;
+        }
+        backdrop.classList.add('gb-overlay-open');
+        if (btn) btn.classList.add('gb-active');
+    }
+}
+function gbCloseOverlay(id, btn) {
+    document.getElementById(id).classList.remove('gb-overlay-open');
+    if (btn) btn.classList.remove('gb-active');
+}
+function gbLoadExample(sel) {
+    var val = sel.value;
+    sel.value = '';
+    if (!val) return;
+    if (typeof openCode === 'function') openCode(val);
+}
+function gbTriggerDownload(sel) {
+    var url = sel.value;
+    sel.value = '';
+    if (!url) return;
+    var a = document.createElement('a');
+    a.href = url;
+    a.download = '';
+    document.body.appendChild(a);
+    a.click();
+    document.body.removeChild(a);
+}
+document.addEventListener('keydown', function(e) {
+    if (e.key === 'Escape') {
+        document.querySelectorAll('.gb-overlay-backdrop').forEach(function(el) {
+            el.classList.remove('gb-overlay-open');
+        });
+        document.querySelectorAll('.gb-btn').forEach(function(el) {
+            el.classList.remove('gb-active');
+        });
+    }
+});
+</script>
